<!DOCTYPE html>
<html>
<head>
    <title>Employee Verification</title>
    <style>
        body { font-family: sans-serif; text-align: center; padding: 50px; transition: 0.5s; }
        
        /* COLOR LOGIC */
        .Allowed { background-color: #28a745; color: white; }
        .Pending { background-color: #ffc107; color: black; }
        .Denied { background-color: #dc3545; color: white; }
        .Denied_Detain { animation: pulse 0.5s infinite; color: white; }

        @keyframes pulse {
            0% { background-color: #dc3545; }
            50% { background-color: #000000; }
            100% { background-color: #dc3545; }
        }

        .card { background: rgba(255,255,255,0.2); padding: 20px; border-radius: 15px; display: inline-block; }
    </style>
</head>
<body class="<%= employee.status.replace(/ /g, '_') %>">
    <div class="card">
        <h1>STATUS: <%= employee.status.toUpperCase() %></h1>
        <hr>
        <h2><%= employee.name %></h2>
        <p>Location: <%= employee.address %></p>
        <p>DOB: <%= employee.dob %></p>
    </div>
</body>
</html>
