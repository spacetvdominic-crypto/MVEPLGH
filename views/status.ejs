<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Verification Portal</title>
    <style>
        /* Base Styling */
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            text-align: center;
            transition: background-color 0.5s ease;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            width: 85%;
            max-width: 400px;
        }

        h1 { margin-bottom: 5px; font-size: 1.8rem; letter-spacing: 2px; }
        h2 { margin: 15px 0 5px 0; color: #333; font-size: 2rem; }
        .info-label { color: #999; font-size: 0.7rem; text-transform: uppercase; margin-top: 10px; }
        .info-value { margin: 2px 0 10px 0; color: #444; font-weight: bold; font-size: 1.1rem; }
        .divider { height: 2px; background: #eee; margin: 20px 0; }

        /* STATUS LOGIC COLORS */
        .Allowed { background-color: #28a745; } /* Green */
        .Allowed .status-text { color: #28a745; }

        .Pending { background-color: #ffc107; } /* Yellow */
        .Pending .status-text { color: #856404; }

        .Denied { background-color: #dc3545; } /* Red */
        .Denied .status-text { color: #dc3545; }

        /* DETENTION ALERT: Flashing Red and Black */
        .Denied_and_Detain { 
            animation: alert-bg 0.6s infinite; 
        }
        
        @keyframes alert-bg {
            0% { background-color: #dc3545; }
            50% { background-color: #000000; }
            100% { background-color: #dc3545; }
        }

        .Denied_and_Detain .card { border: 6px solid yellow; }
        .Denied_and_Detain .status-text { color: red; font-weight: 900; }

        .back-btn {
            margin-top: 20px;
            display: inline-block;
            text-decoration: none;
            color: #666;
            font-size: 0.8rem;
            border: 1px solid #ccc;
            padding: 5px 10px;
            border-radius: 5px;
        }
    </style>
</head>

<body class="<%= employee.status.replace(/ /g, '_') %>">

    <div class="card">
        <p class="info-label" style="letter-spacing: 3px;">MANET VILLE Security Verification</p>
        <h1 class="status-text"><%= employee.status.toUpperCase() %></h1>
        
        <div class="divider"></div>

        <p class="info-label">Full Name</p>
        <h2><%= employee.name %></h2>
        
        <p class="info-label">Employee ID</p>
        <p class="info-value"><%= employee.id %></p>

        <p class="info-label">Assigned Location</p>
        <p class="info-value"><%= employee.address %></p>
        
        <div class="divider"></div>
        
        <p style="font-size: 0.75rem; color: #999;">Verified: <%= new Date().toLocaleString() %></p>
        
        <a href="/" class="back-btn">← Manual Entry</a>
    </div>

</body>
</html>
