<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Employee Verification Portal</title>
    <style>
        /* Base Styling */
        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            margin: 0;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            text-align: center;
            transition: background-color 0.5s ease;
        }

        .card {
            background: white;
            padding: 30px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            width: 80%;
            max-width: 400px;
        }

        h1 { margin-bottom: 10px; font-size: 1.5rem; }
        h2 { margin: 10px 0; color: #333; }
        p { margin: 5px 0; color: #666; font-weight: bold; }
        .divider { height: 2px; background: #eee; margin: 20px 0; }

        /* STATUS LOGIC COLORS */
        /* These classes match the options in your Google Sheet dropdown */

        .Allowed { background-color: #28a745; } /* Green */
        .Allowed .status-text { color: #28a745; }

        .Pending { background-color: #ffc107; } /* Yellow */
        .Pending .status-text { color: #856404; }

        .Denied { background-color: #dc3545; } /* Red */
        .Denied .status-text { color: #dc3545; }

        /* DETENTION ALERT: Flashing Red and Black */
        .Denied_and_Detain { 
            animation: alert-bg 0.6s infinite; 
        }
        
        @keyframes alert-bg {
            0% { background-color: #dc3545; }
            50% { background-color: #000000; }
            100% { background-color: #dc3545; }
        }

        .Denied_and_Detain .card { border: 5px solid yellow; }
        .Denied_and_Detain .status-text { color: red; font-weight: 900; }

    </style>
</head>

<body class="<%= employee.status.replace(/ /g, '_') %>">

    <div class="card">
        <p>SECURITY VERIFICATION</p>
        <h1 class="status-text"><%= employee.status.toUpperCase() %></h1>
        
        <div class="divider"></div>

        <h2><%= employee.name %></h2>
        <p>ID: <%= employee.id %></p>
        <p>Assigned to: <%= employee.address %></p>
        
        <div class="divider"></div>
        
        <p style="font-size: 0.8rem; color: #999;">Verified via Real-Time Estate Database</p>
    </div>

</body>
</html>
