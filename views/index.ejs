<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manet Ville Estate Security Dashboard</title>
    <style>
        body { 
            font-family: 'Segoe UI', sans-serif; 
            background-color: #1a1a1a; 
            color: white; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            margin: 0; 
        }
        .container { 
            background: #2a2a2a; 
            padding: 40px; 
            border-radius: 20px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.5); 
            text-align: center;
            width: 90%;
            max-width: 400px;
        }
        h1 { color: #00ff88; margin-bottom: 25px; }
        input { 
            width: 100%; 
            padding: 15px; 
            margin-bottom: 20px; 
            border: none; 
            border-radius: 10px; 
            font-size: 1.1rem; 
            box-sizing: border-box;
            background: #333;
            color: white;
        }
        button { 
            width: 100%; 
            padding: 15px; 
            background-color: #00ff88; 
            color: #1a1a1a; 
            border: none; 
            border-radius: 10px; 
            font-size: 1.1rem; 
            font-weight: bold; 
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* LOADING SPINNER CSS */
        .spinner {
            display: none; /* Hidden by default */
            width: 20px;
            height: 20px;
            border: 3px solid rgba(26, 26, 26, 0.3);
            border-radius: 50%;
            border-top-color: #1a1a1a;
            animation: spin 1s ease-in-out infinite;
            margin-left: 10px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Disable button look when loading */
        .loading-active { background-color: #00cc6e; cursor: not-allowed; }
    </style>
</head>
<body>
    <div class="container" id="main-content">
        <h1>MANET VILLE ESTATE ACCESS</h1>
        <p style="color: #aaa; margin-bottom: 30px;">Manual ID Verification Portal</p>
        
        <form action="/verify" method="GET" onsubmit="showLoading()">
            <input type="text" name="id" placeholder="ENTER EMPLOYEE ID" required autocomplete="off">
            <button type="submit" id="submit-btn">
                <span id="btn-text">VERIFY STATUS</span>
                <div class="spinner" id="loader"></div>
            </button>
        </form>
    </div>

    <script>
        function showLoading() {
            const btn = document.getElementById('submit-btn');
            const loader = document.getElementById('loader');
            const btnText = document.getElementById('btn-text');

            // Change button appearance
            btn.classList.add('loading-active');
            btnText.innerText = "CHECKING DATABASE...";
            loader.style.display = "block";
            
            // Prevent double-clicking
            btn.disabled = true;
            btn.form.submit();
        }
    </script>
</body>
</html>
