<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manet Ville Estate Security Dashboard</title>
    <style>
        body { 
            font-family: 'Segoe UI', sans-serif; 
            background-color: #1a1a1a; 
            color: white; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            margin: 0; 
        }
        .container { 
            background: #2a2a2a; 
            padding: 40px; 
            border-radius: 20px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.5); 
            text-align: center;
            width: 90%;
            max-width: 400px;
        }
        h1 { color: #00ff88; margin-bottom: 25px; }
        p { color: #aaa; margin-bottom: 30px; }
        input { 
            width: 100%; 
            padding: 15px; 
            margin-bottom: 20px; 
            border: none; 
            border-radius: 10px; 
            font-size: 1.1rem; 
            box-sizing: border-box;
        }
        button { 
            width: 100%; 
            padding: 15px; 
            background-color: #00ff88; 
            color: #1a1a1a; 
            border: none; 
            border-radius: 10px; 
            font-size: 1.1rem; 
            font-weight: bold; 
            cursor: pointer;
            transition: 0.3s;
        }
        button:hover { background-color: #00cc6e; transform: scale(1.02); }
    </style>
</head>
<body>
    <div class="container">
        <h1>MANET VILLE ESTATE ACCESS</h1>
        <p>Manual ID Verification Portal</p>
        <form action="/verify" method="GET">
            <input type="text" name="id" placeholder="ENTER EMPLOYEE ID" required autocomplete="off">
            <button type="submit">VERIFY STATUS</button>
        </form>
        <div style="margin-top: 20px; font-size: 0.8rem; color: #555;">
            SYSTEM v2.0 | SECURE ENCRYPTED LINK
        </div>
    </div>
</body>
</html>
